# База данных
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=hotel
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@db:5432/hotel

# Приложение
DEBUG=true
SECRET_KEY=your_secret_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=hotel_webhook_verify

# WhatsApp (wappi.pro)
WAPPI_API_KEY=
WAPPI_PROFILE_ID=

# AI (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=deepseek/deepseek-chat

# CORS
CORS_ORIGINS=http://localhost:3000

# Часовой пояс
TZ=Asia/Bishkek

# Exely (система бронирования)
EXELY_API_KEY=
EXELY_HOTEL_CODE=
