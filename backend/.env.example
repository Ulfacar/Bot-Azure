# Скопируй этот файл как .env и заполни значения

# База данных (Neon)
DATABASE_URL=postgresql+asyncpg://user:password@host/hotel
DATABASE_SSL=true

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=hotel_webhook_verify

# AI (OpenRouter)
OPENROUTER_API_KEY=your-openrouter-api-key
AI_MODEL=deepseek/deepseek-chat

# Безопасность
SECRET_KEY=change-me-in-production

# CORS
CORS_ORIGINS=http://localhost:3000

# Часовой пояс
TZ=Asia/Bishkek

# Режим
DEBUG=false
